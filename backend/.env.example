# PostgreSQL connection string used by Prisma.
# For local development with docker-compose, the default credentials below match.
# Never commit a real .env file — see .gitignore.
# Docker-compose Postgres runs on 5434 to avoid clashing with host-installed PG on 5432/5433.
DATABASE_URL="postgresql://library:library@localhost:5434/library?schema=public"

# Separate database for the Jest+Supertest suite (chapter 14). Create it once
# with: docker exec library-postgres psql -U library -d library -c "CREATE DATABASE library_test"
# The test harness (tests/setup-env.ts) maps this onto DATABASE_URL at runtime.
DATABASE_URL_TEST="postgresql://library:library@localhost:5434/library_test?schema=public"

# JWT signing keys. Generate with `openssl rand -base64 64`.
JWT_ACCESS_SECRET="replace-me-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-me-with-a-different-long-random-string"

# Access tokens live for 15 minutes, refresh tokens for 30 days.
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
